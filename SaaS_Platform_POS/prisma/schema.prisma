// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// TENANTS & USERS
// ============================================

enum SubscriptionPlan {
  FREE_TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  businessType String @map("business_type") // HOTEL, RESTAURANT, RETAIL
  gstNumber String?  @map("gst_number")
  address   String?
  phone     String?
  email     String?
  
  // Subscription Management
  subscriptionPlan   SubscriptionPlan   @default(FREE_TRIAL) @map("subscription_plan")
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  trialStartDate     DateTime?          @map("trial_start_date")
  trialEndDate       DateTime?          @map("trial_end_date")
  subscriptionStartDate DateTime?       @map("subscription_start_date")
  subscriptionEndDate   DateTime?       @map("subscription_end_date")
  billingCycle       String?            @default("MONTHLY") // MONTHLY or YEARLY
  
  // Usage Tracking
  usageStats         Json?              @default("{}") @map("usage_stats") // Track bills, items, users count
  
  // Configuration
  inventoryMethod String @default("FIFO") @map("inventory_method") // FIFO or WEIGHTED_AVERAGE
  currency        String @default("INR")
  timezone        String @default("Asia/Kolkata")
  settings        Json?  @default("{}") // Dynamic business settings (KOT enabled, auto-print, etc.)
  
  // Status
  isActive  Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  
  // Relations
  users       User[]
  locations   Location[]
  customers   Customer[]
  categories  Category[]
  items       Item[]
  inventoryBatches InventoryBatch[]
  ingredients Ingredient[]
  purchases   Purchase[]
  bills       Bill[]
  kots        KOT[]
  tables      Table[]
  tableReservations TableReservation[]
  printJobs   PrintJob[]
  auditLogs   AuditLog[]
  loyaltyTransactions LoyaltyTransaction[]
  invoices    Invoice[]
  
  // Professional Plan features
  vendors     Vendor[]
  recipes     Recipe[]
  wastageLogs WastageLog[]
  bankAccounts BankAccount[]
  transportAgents TransportAgent[]
  brandings   Branding[]
  
  @@map("tenants")
}

enum UserRole {
  SUPER_ADMIN // Platform admin with access to all tenants
  OWNER
  MANAGER
  CASHIER
  KITCHEN
}

model User {
  id       String   @id @default(uuid())
  tenantId String?  @map("tenant_id") // Optional for SUPER_ADMIN
  locationId String? @map("location_id") // Optional: If assigned, user can only access this location
  
  username String   @unique
  password String   // Hashed password
  email    String
  name     String
  phone    String?
  role     UserRole
  
  // Status
  isActive  Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  
  // Relations
  tenant    Tenant?   @relation(fields: [tenantId], references: [id])
  location  Location? @relation(fields: [locationId], references: [id])
  bills     Bill[]
  kots      KOT[]
  auditLogs AuditLog[]
  
  @@index([tenantId])
  @@index([locationId])
  @@index([username])
  @@map("users")
}

// ============================================
// ITEMS & CATEGORIES
// ============================================

model Category {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  
  // Status
  isActive    Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  
  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  items       Item[]
  
  @@index([tenantId])
  @@map("categories")
}

enum ItemType {
  SIMPLE    // Fixed quantity items
  WEIGHTED  // Items sold by weight
}

enum InventoryMode {
  AUTO      // Auto-deduct inventory on billing
  MANUAL    // Manual inventory management (infinity quantity)
}

model Item {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  categoryId  String   @map("category_id")
  
  name        String
  description String?
  sku         String?
  itemType    ItemType @default(SIMPLE) @map("item_type")
  
  // Pricing
  price       Decimal  @db.Decimal(10, 2)
  gstRate     Decimal  @default(0) @map("gst_rate") @db.Decimal(5, 2) // GST percentage
  
  // HSN/SAC Codes for GST
  hsnCode     String?  @map("hsn_code")
  sacCode     String?  @map("sac_code")
  
  // Inventory tracking
  trackInventory Boolean       @default(true) @map("track_inventory")
  inventoryMode  InventoryMode @default(AUTO) @map("inventory_mode")
  unit           String        @default("PCS") // PCS, KG, L, etc.
  
  // Simple Quantity Tracking (Starter Plan)
  quantity       Decimal       @default(0) @db.Decimal(10, 3) // Simple quantity for Starter plan
  
  // Advanced Inventory (Professional Plan)
  isComposite    Boolean       @default(false) @map("is_composite") // Is this a recipe/BOM item?
  reorderLevel   Decimal?      @map("reorder_level") @db.Decimal(10, 3) // Alert when stock below this
  reorderQuantity Decimal?     @map("reorder_quantity") @db.Decimal(10, 3) // Suggested purchase quantity
  
  // Status
  isActive    Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  
  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  category    Category @relation(fields: [categoryId], references: [id])
  inventoryBatches InventoryBatch[]
  billItems   BillItem[]
  kotItems    KOTItem[]
  purchaseItems PurchaseItem[]
  invoiceItems InvoiceItem[]
  
  // Recipe/BOM relations (Professional Plan)
  recipes          Recipe[]           @relation("FinishedGood") // This item as a finished good
  wastageLogs      WastageLog[]
  
  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId])
  @@map("items")
}

// ============================================
// INVENTORY MANAGEMENT
// ============================================

model InventoryBatch {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  itemId          String?  @map("item_id") // For finished goods (Professional Plan)
  ingredientId    String?  @map("ingredient_id") // For raw materials (Professional Plan)
  purchaseId      String?  @map("purchase_id")
  locationId      String?  @map("location_id") // Multi-location support
  
  // Batch details
  batchNumber     String   @map("batch_number")
  initialQuantity Decimal  @map("initial_quantity") @db.Decimal(10, 3)
  currentQuantity Decimal  @map("current_quantity") @db.Decimal(10, 3)
  costPrice       Decimal  @map("cost_price") @db.Decimal(10, 2)
  
  // Dates
  purchaseDate    DateTime @map("purchase_date")
  expiryDate      DateTime? @map("expiry_date")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  item            Item?      @relation(fields: [itemId], references: [id])
  ingredient      Ingredient? @relation(fields: [ingredientId], references: [id])
  purchase        Purchase?  @relation(fields: [purchaseId], references: [id])
  location        Location?  @relation(fields: [locationId], references: [id])
  billItemBatches BillItemBatch[]
  invoiceItemBatches InvoiceItemBatch[]
  wastageLogs     WastageLog[]
  
  @@index([tenantId])
  @@index([itemId])
  @@index([ingredientId])
  @@index([purchaseId])
  @@index([locationId])
  @@map("inventory_batches")
}

// ============================================
// INGREDIENTS (Starter Plan - Simple Inventory)
// ============================================

model Ingredient {
  id                String           @id @default(uuid())
  tenantId          String           @map("tenant_id")
  
  name              String
  unit              String           // KG, G, L, ML, PCS, PACKETS, POUCHES, etc.
  quantity          Decimal          @default(0) @db.Decimal(10, 3) // For Starter Plan simple tracking
  
  // Status
  isActive          Boolean          @default(true) @map("is_active")
  
  // Timestamps
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")
  
  // Relations
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  recipeIngredients RecipeIngredient[] // Used in recipes
  purchaseItems     PurchaseItem[]   // Professional Plan: Purchase orders
  inventoryBatches  InventoryBatch[] // Professional Plan: Batch tracking
  
  @@index([tenantId])
  @@map("ingredients")
}

// ============================================
// PURCHASES
// ============================================

enum PurchaseStatus {
  DRAFT        // Creating purchase order
  ORDERED      // PO sent to vendor (Professional Plan)
  RECEIVED     // Goods received (GRN)
  CANCELLED
}

model Purchase {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  vendorId        String?        @map("vendor_id") // Professional Plan: Link to Vendor
  
  purchaseNumber  String         @unique @map("purchase_number")
  supplierName    String?        @map("supplier_name") // Fallback if no vendor linked
  invoiceNumber   String?        @map("invoice_number")
  
  status          PurchaseStatus @default(DRAFT)
  totalAmount     Decimal        @map("total_amount") @db.Decimal(10, 2)
  
  // Dates
  purchaseDate    DateTime       @map("purchase_date")
  orderedDate     DateTime?      @map("ordered_date")  // Professional Plan: When PO sent
  receivedDate    DateTime?      @map("received_date") // When goods received
  expectedDate    DateTime?      @map("expected_date") // Professional Plan: Expected delivery
  
  notes           String?
  
  // Timestamps
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")
  
  // Relations
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  vendor          Vendor?        @relation(fields: [vendorId], references: [id]) // Professional Plan
  items           PurchaseItem[]
  inventoryBatches InventoryBatch[]
  
  @@index([tenantId])
  @@index([vendorId])
  @@map("purchases")
}

model PurchaseItem {
  id           String      @id @default(uuid())
  purchaseId   String      @map("purchase_id")
  itemId       String?     @map("item_id") // For finished goods
  ingredientId String?     @map("ingredient_id") // For raw materials
  
  quantity     Decimal     @db.Decimal(10, 3)
  costPrice    Decimal     @map("cost_price") @db.Decimal(10, 2)
  totalCost    Decimal     @map("total_cost") @db.Decimal(10, 2)
  
  // Timestamps
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  
  // Relations
  purchase     Purchase    @relation(fields: [purchaseId], references: [id])
  item         Item?       @relation(fields: [itemId], references: [id])
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])
  
  @@index([purchaseId])
  @@index([itemId])
  @@index([ingredientId])
  @@map("purchase_items")
}

// ============================================
// VENDOR MANAGEMENT (Professional Plan)
// ============================================

model Vendor {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  
  // Basic Info
  name            String
  contactPerson   String?  @map("contact_person")
  phone           String?
  email           String?
  
  // Address
  address         String?
  city            String?
  state           String?
  pincode         String?
  country         String?  @default("India")
  
  // Business Details
  gstNumber       String?  @map("gst_number")
  panNumber       String?  @map("pan_number")
  
  // Payment Terms (Professional Plan)
  paymentTerms    String?  @default("NET_30") @map("payment_terms") // NET_30, NET_60, COD, etc.
  creditLimit     Decimal? @map("credit_limit") @db.Decimal(10, 2)
  
  // Banking
  bankName        String?  @map("bank_name")
  accountNumber   String?  @map("account_number")
  ifscCode        String?  @map("ifsc_code")
  
  // Metadata
  notes           String?
  tags            String[] @default([])
  
  // Status
  isActive        Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  
  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  purchases       Purchase[]
  
  @@index([tenantId])
  @@map("vendors")
}

// ============================================
// RECIPE/BOM MANAGEMENT (Professional Plan - F&B)
// ============================================

model Recipe {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  finishedGoodId  String   @map("finished_good_id") // The item this recipe produces
  
  name            String   // Recipe name (e.g., "Margherita Pizza Recipe")
  description     String?
  
  // Yield information
  yieldQuantity   Decimal  @default(1) @map("yield_quantity") @db.Decimal(10, 3) // How many units this recipe makes
  yieldUnit       String   @default("PCS") @map("yield_unit") // PCS, KG, L, etc.
  
  // Costing
  preparationTime Int?     @map("preparation_time") // In minutes
  
  // Status
  isActive        Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  
  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  finishedGood    Item     @relation("FinishedGood", fields: [finishedGoodId], references: [id])
  ingredients     RecipeIngredient[]
  
  @@index([tenantId])
  @@index([finishedGoodId])
  @@map("recipes")
}

model RecipeIngredient {
  id              String   @id @default(uuid())
  recipeId        String   @map("recipe_id")
  ingredientId    String   @map("ingredient_id") // The raw material from Ingredient table
  
  // Quantity required
  quantity        Decimal  @db.Decimal(10, 3)
  unit            String   @default("PCS")
  
  // Cost allocation
  wastagePercent  Decimal  @default(0) @map("wastage_percent") @db.Decimal(5, 2) // Expected wastage %
  
  notes           String?
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  // Relations
  recipe          Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  
  @@index([recipeId])
  @@index([ingredientId])
  @@map("recipe_ingredients")
}

// ============================================
// WASTAGE TRACKING (Professional Plan)
// ============================================

enum WastageReason {
  EXPIRED
  DAMAGED
  SPILLAGE
  THEFT
  OTHER
}

model WastageLog {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  itemId          String        @map("item_id")
  batchId         String?       @map("batch_id") // Optional: specific batch
  
  // Wastage details
  quantity        Decimal       @db.Decimal(10, 3)
  reason          WastageReason
  description     String?
  
  // Financial impact
  estimatedValue  Decimal       @map("estimated_value") @db.Decimal(10, 2)
  
  // Recorded by
  recordedBy      String        @map("recorded_by") // User ID
  recordedAt      DateTime      @default(now()) @map("recorded_at")
  
  // Timestamps
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  
  // Relations
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  item            Item          @relation(fields: [itemId], references: [id])
  batch           InventoryBatch? @relation(fields: [batchId], references: [id])
  
  @@index([tenantId])
  @@index([itemId])
  @@index([batchId])
  @@index([recordedAt])
  @@map("wastage_logs")
}

// ============================================
// BILLING
// ============================================

enum BillStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  OTHER
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

model Bill {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  userId          String        @map("user_id")
  kotId           String?       @map("kot_id")
  locationId      String?       @map("location_id")  // Professional feature
  customerId      String?       @map("customer_id")  // Professional feature
  
  billNumber      String        @map("bill_number")
  
  // Amounts
  subtotal        Decimal       @db.Decimal(10, 2)
  taxAmount       Decimal       @map("tax_amount") @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(10, 2)
  
  // Loyalty (Professional feature)
  pointsEarned    Int?          @default(0) @map("points_earned")
  pointsRedeemed  Int?          @default(0) @map("points_redeemed")
  
  // Payment
  paymentMethod   PaymentMethod @map("payment_method")
  paymentStatus   String        @default("PAID") @map("payment_status")
  
  // Order Type
  orderType       OrderType?    @map("order_type")
  
  // Status
  status          BillStatus    @default(COMPLETED)
  
  // Customer info (optional - for backward compatibility)
  customerName    String?       @map("customer_name")
  customerPhone   String?       @map("customer_phone")
  
  notes           String?
  
  // Timestamps
  billedAt        DateTime      @default(now()) @map("billed_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  cancelledAt     DateTime?     @map("cancelled_at")
  
  // Relations
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  kot             KOT?          @relation(fields: [kotId], references: [id])
  location        Location?     @relation(fields: [locationId], references: [id])
  customer        Customer?     @relation(fields: [customerId], references: [id])
  items           BillItem[]
  printJobs       PrintJob[]
  loyaltyTransactions LoyaltyTransaction[]
  invoice         Invoice?
  
  @@unique([tenantId, billNumber])
  @@index([tenantId])
  @@index([userId])
  @@index([locationId])
  @@index([customerId])
  @@index([billNumber])
  @@map("bills")
}

model BillItem {
  id          String   @id @default(uuid())
  billId      String   @map("bill_id")
  itemId      String   @map("item_id")
  
  quantity    Decimal  @db.Decimal(10, 3)
  price       Decimal  @db.Decimal(10, 2)
  gstRate     Decimal  @map("gst_rate") @db.Decimal(5, 2)
  gstAmount   Decimal  @map("gst_amount") @db.Decimal(10, 2)
  totalAmount Decimal  @map("total_amount") @db.Decimal(10, 2)
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relations
  bill        Bill     @relation(fields: [billId], references: [id])
  item        Item     @relation(fields: [itemId], references: [id])
  batches     BillItemBatch[]
  
  @@index([billId])
  @@index([itemId])
  @@map("bill_items")
}

// Junction table for tracking which inventory batches were used
model BillItemBatch {
  id              String         @id @default(uuid())
  billItemId      String         @map("bill_item_id")
  batchId         String         @map("batch_id")
  
  quantityUsed    Decimal        @map("quantity_used") @db.Decimal(10, 3)
  costPrice       Decimal        @map("cost_price") @db.Decimal(10, 2)
  
  // Timestamps
  createdAt       DateTime       @default(now()) @map("created_at")
  
  // Relations
  billItem        BillItem       @relation(fields: [billItemId], references: [id])
  batch           InventoryBatch @relation(fields: [batchId], references: [id])
  
  @@index([billItemId])
  @@index([batchId])
  @@map("bill_item_batches")
}

// ============================================
// KOT (Kitchen Order Ticket)
// ============================================

enum KOTStatus {
  PENDING
  PREPARING
  READY
  SERVED
  BILLED
  CANCELLED
}

model KOT {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  userId      String     @map("user_id")
  locationId  String?    @map("location_id")
  tableId     String?    @map("table_id")
  
  kotNumber   String     @unique @map("kot_number")
  tableNumber String?    @map("table_number") // Legacy field, kept for backward compatibility
  
  status      KOTStatus  @default(PENDING)
  
  notes       String?
  
  // Timestamps
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  billedAt    DateTime?  @map("billed_at")
  
  // Relations
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  location    Location?  @relation(fields: [locationId], references: [id])
  table       Table?     @relation(fields: [tableId], references: [id])
  items       KOTItem[]
  bills       Bill[]
  printJobs   PrintJob[]
  
  @@index([tenantId])
  @@index([userId])
  @@index([locationId])
  @@index([tableId])
  @@map("kots")
}

model KOTItem {
  id          String   @id @default(uuid())
  kotId       String   @map("kot_id")
  itemId      String   @map("item_id")
  
  quantity    Decimal  @db.Decimal(10, 3)
  notes       String?
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relations
  kot         KOT      @relation(fields: [kotId], references: [id])
  item        Item     @relation(fields: [itemId], references: [id])
  
  @@index([kotId])
  @@index([itemId])
  @@map("kot_items")
}

// ============================================
// PRINTING
// ============================================

enum PrintJobType {
  BILL
  KOT
}

enum PrintJobStatus {
  PENDING
  PRINTING
  COMPLETED
  FAILED
}

model PrintJob {
  id          String         @id @default(uuid())
  tenantId    String         @map("tenant_id")
  billId      String?        @map("bill_id")
  kotId       String?        @map("kot_id")
  
  jobType     PrintJobType   @map("job_type")
  status      PrintJobStatus @default(PENDING)
  
  // Print payload (JSON)
  payload     Json
  
  // Retry tracking
  attempts    Int            @default(0)
  maxAttempts Int            @default(3) @map("max_attempts")
  lastError   String?        @map("last_error")
  
  // Timestamps
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  completedAt DateTime?      @map("completed_at")
  
  // Relations
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  bill        Bill?          @relation(fields: [billId], references: [id])
  kot         KOT?           @relation(fields: [kotId], references: [id])
  
  @@index([tenantId])
  @@index([status])
  @@map("print_jobs")
}

// ============================================
// AUDIT LOGS
// ============================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  CANCEL
  RESTORE
}

model AuditLog {
  id          String      @id @default(uuid())
  tenantId    String      @map("tenant_id")
  userId      String      @map("user_id")
  
  action      AuditAction
  entity      String      // Table/model name
  entityId    String      @map("entity_id")
  
  // Change tracking
  beforeData  Json?       @map("before_data")
  afterData   Json?       @map("after_data")
  
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  
  // Timestamps
  createdAt   DateTime    @default(now()) @map("created_at")
  
  // Relations
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  
  @@index([tenantId])
  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ============================================
// LOCATIONS (Professional Feature)
// ============================================

model Location {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  
  name        String   // "Main Store", "Mall Branch"
  code        String   // "MS01", "MB02"
  address     String?
  city        String?
  state       String?
  pincode     String?
  phone       String?
  email       String?
  
  // Location settings
  isHeadquarters Boolean  @default(false) @map("is_headquarters")
  allowStockTransfer Boolean @default(true) @map("allow_stock_transfer")
  settings    Json?    @default("{}")
  
  // Status
  isActive    Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  
  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  users       User[]   // Users assigned to this location
  bills       Bill[]
  kots        KOT[]
  inventoryBatches InventoryBatch[]
  stockTransfersFrom StockTransfer[] @relation("TransferFrom")
  stockTransfersTo   StockTransfer[] @relation("TransferTo")
  tables      Table[]
  tableReservations TableReservation[]
  invoices    Invoice[]
  bankAccounts BankAccount[]
  transportAgents TransportAgent[]
  brandings   Branding[]
  
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("locations")
}

// ============================================
// TABLE MANAGEMENT (Restaurant/Cafe/Hotel)
// ============================================

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  BILLED
  CLEANING
  OUT_OF_SERVICE
}

enum ReservationStatus {
  PENDING       // Reservation created but not yet confirmed
  CONFIRMED     // Reservation confirmed by staff/customer
  SEATED        // Customer has arrived and been seated
  CANCELLED     // Reservation cancelled
  NO_SHOW       // Customer didn't show up
  COMPLETED     // Reservation fulfilled successfully
}

model Table {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  locationId  String   @map("location_id")
  
  // Table Details
  tableNumber String   @map("table_number")
  tableName   String?  @map("table_name")
  capacity    Int      @default(4)
  section     String?  // "Indoor", "Outdoor", "VIP", "Terrace"
  floor       String?  // "Ground Floor", "First Floor"
  
  // Status Tracking
  status      TableStatus @default(FREE)
  currentKotId String?  @map("current_kot_id")
  occupiedAt  DateTime? @map("occupied_at")
  lastBilledAt DateTime? @map("last_billed_at")
  
  // Layout/Visual (per location)
  positionX   Int?     @map("position_x")
  positionY   Int?     @map("position_y")
  layoutZone  String?  @map("layout_zone")
  rotation    Int?     @default(0) // Rotation angle 0-360 degrees
  width       Int?     @default(80) // Visual width in pixels
  height      Int?     @default(80) // Visual height in pixels
  shape       String?  @default("rectangle") // rectangle, circle, square
  
  // Metadata
  qrCode      String?  @unique @map("qr_code")
  notes       String?
  isActive    Boolean  @default(true) @map("is_active")
  
  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  location    Location @relation(fields: [locationId], references: [id])
  kots        KOT[]
  reservations TableReservation[]
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  
  @@unique([locationId, tableNumber])
  @@index([tenantId, locationId, status])
  @@index([locationId, status])
  @@map("tables")
}

// ============================================
// TABLE RESERVATIONS
// ============================================

model TableReservation {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  locationId String   @map("location_id")
  tableId    String   @map("table_id")
  
  // Reservation Details
  customerName  String  @map("customer_name")
  customerPhone String  @map("customer_phone")
  customerEmail String? @map("customer_email")
  
  // Mandatory Fields
  numberOfPeople      Int       @map("number_of_people") // Number of seats required
  reservationDate     DateTime  @map("reservation_date") // Date of reservation
  reservationTime     DateTime  @map("reservation_time") // Time of reservation
  duration            Int?      @default(120) // Duration in minutes (default 2 hours)
  
  // Special Arrangements (Mandatory)
  specialRequirements String?   @map("special_requirements") // Any special arrangements needed
  
  // Pre-order (Optional)
  preOrderItems Json?  @map("pre_order_items") // Array of items to be prepared ahead
  preOrderNotes String? @map("pre_order_notes")
  
  // Status Management
  status            ReservationStatus @default(PENDING)
  confirmationCode  String?  @unique @map("confirmation_code")
  confirmedAt       DateTime? @map("confirmed_at")
  arrivedAt         DateTime? @map("arrived_at") // When customer actually arrived
  cancelledAt       DateTime? @map("cancelled_at")
  cancellationReason String? @map("cancellation_reason")
  
  // Metadata
  notes       String?
  createdBy   String?  @map("created_by") // User ID who created the reservation
  
  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  location    Location @relation(fields: [locationId], references: [id])
  table       Table    @relation(fields: [tableId], references: [id])
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  
  @@index([tenantId, status, reservationDate])
  @@index([locationId, reservationDate])
  @@index([tableId, status])
  @@index([customerPhone])
  @@map("table_reservations")
}

// ============================================
// STOCK TRANSFERS (Professional Feature)
// ============================================

enum TransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

model StockTransfer {
  id              String         @id @default(uuid())
  tenantId        String         @map("tenant_id")
  fromLocationId  String         @map("from_location_id")
  toLocationId    String         @map("to_location_id")
  
  transferNumber  String         @unique @map("transfer_number")
  status          TransferStatus @default(PENDING)
  
  items           Json           // Array of {itemId, quantity, batchId}
  notes           String?
  
  // Tracking
  sentBy          String?        @map("sent_by")
  sentAt          DateTime?      @map("sent_at")
  receivedBy      String?        @map("received_by")
  receivedAt      DateTime?      @map("received_at")
  
  // Timestamps
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  
  // Relations
  fromLocation    Location       @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocation      Location       @relation("TransferTo", fields: [toLocationId], references: [id])
  
  @@index([tenantId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@map("stock_transfers")
}

// ============================================
// CUSTOMERS & CRM (Professional Feature)
// ============================================

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  VIP
}

model Customer {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id")
  
  // Basic Info
  name           String
  phone          String
  email          String?
  dateOfBirth    DateTime?      @map("date_of_birth")
  anniversary    DateTime?
  
  // Address
  address        String?
  city           String?
  state          String?
  pincode        String?
  
  // CRM Data
  tier           CustomerTier   @default(BRONZE)
  loyaltyPoints  Int            @default(0) @map("loyalty_points")
  totalSpent     Decimal        @default(0) @map("total_spent") @db.Decimal(10, 2)
  visitCount     Int            @default(0) @map("visit_count")
  lastVisitAt    DateTime?      @map("last_visit_at")
  
  // Marketing
  tags           String[]       @default([])
  notes          String?
  marketingOptIn Boolean        @default(true) @map("marketing_opt_in")
  
  // Status
  isActive       Boolean        @default(true) @map("is_active")
  
  // Timestamps
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")
  
  // Relations
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  bills          Bill[]
  invoices       Invoice[]
  loyaltyTransactions LoyaltyTransaction[]
  
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([phone])
  @@index([email])
  @@map("customers")
}

// ============================================
// LOYALTY PROGRAM (Professional Feature)
// ============================================

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED
}

model LoyaltyTransaction {
  id          String                 @id @default(uuid())
  tenantId    String                 @map("tenant_id")
  customerId  String                 @map("customer_id")
  
  type        LoyaltyTransactionType
  points      Int                    // Positive for earning, negative for redemption
  billId      String?                @map("bill_id")
  
  description String?
  expiresAt   DateTime?              @map("expires_at")
  
  // Timestamps
  createdAt   DateTime               @default(now()) @map("created_at")
  
  // Relations
  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  customer    Customer               @relation(fields: [customerId], references: [id])
  bill        Bill?                  @relation(fields: [billId], references: [id])
  
  @@index([tenantId])
  @@index([customerId])
  @@index([billId])
  @@map("loyalty_transactions")
}

// ============================================
// INVOICE MANAGEMENT (Professional Plan - RETAIL)
// ============================================

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  locationId      String?       @map("location_id")
  customerId      String        @map("customer_id")
  billId          String?       @unique @map("bill_id")
  bankAccountId   String?       @map("bank_account_id")
  transportAgentId String?      @map("transport_agent_id")
  
  // Numbering
  invoiceNumber   String        @map("invoice_number")
  invoiceDate     DateTime      @default(now()) @map("invoice_date")
  dueDate         DateTime      @map("due_date")
  paymentTerms    String        @default("Net 30") @map("payment_terms")
  
  // Amounts
  subtotal        Decimal       @db.Decimal(10, 2)
  taxAmount       Decimal       @db.Decimal(10, 2) @map("tax_amount")
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  shippingCharge  Decimal       @default(0) @db.Decimal(10, 2) @map("shipping_charge")
  totalAmount     Decimal       @db.Decimal(10, 2) @map("total_amount")
  
  // Transport & E-Way Bill Details
  challanNumber   String?       @map("challan_number")
  challanDate     DateTime?     @map("challan_date")
  ewayBillNumber  String?       @map("eway_bill_number")
  ewayBillDate    DateTime?     @map("eway_bill_date")
  vehicleNumber   String?       @map("vehicle_number")
  lrNumber        String?       @map("lr_number")
  placeOfSupply   String?       @map("place_of_supply")
  
  // Status tracking
  status          InvoiceStatus @default(DRAFT)
  
  // Customer snapshot (capture at creation time)
  customerName    String        @map("customer_name")
  customerPhone   String        @map("customer_phone")
  customerEmail   String?       @map("customer_email")
  customerAddress String?       @db.Text @map("customer_address")
  customerCity    String?       @map("customer_city")
  customerState   String?       @map("customer_state")
  customerPincode String?       @map("customer_pincode")
  customerGSTIN   String?       @map("customer_gstin")
  
  // Template customization
  templateId      String        @default("template-1") @map("template_id")
  templateConfig  Json?         @map("template_config")
  
  // Additional info
  notes           String?       @db.Text
  termsConditions String?       @db.Text @map("terms_conditions")
  signatureUrl    String?       @map("signature_url")
  
  // Timestamps
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  sentAt          DateTime?     @map("sent_at")
  paidAt          DateTime?     @map("paid_at")
  deletedAt       DateTime?     @map("deleted_at")
  
  // Relations
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  location        Location?        @relation(fields: [locationId], references: [id])
  customer        Customer         @relation(fields: [customerId], references: [id])
  bill            Bill?            @relation(fields: [billId], references: [id])
  bankAccount     BankAccount?     @relation(fields: [bankAccountId], references: [id])
  transportAgent  TransportAgent?  @relation(fields: [transportAgentId], references: [id])
  items           InvoiceItem[]
  payments        InvoicePayment[]
  
  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, locationId])
  @@index([customerId])
  @@index([status])
  @@index([invoiceDate])
  @@map("invoices")
}

model InvoiceItem {
  id            String   @id @default(uuid())
  invoiceId     String   @map("invoice_id")
  itemId        String?  @map("item_id")
  
  // Item snapshot
  itemName      String   @map("item_name")
  itemCode      String?  @map("item_code")
  description   String?  @db.Text
  unit          String   @default("PCS")
  
  // Pricing
  quantity      Decimal  @db.Decimal(10, 3)
  price         Decimal  @db.Decimal(10, 2)
  gstRate       Decimal  @default(0) @db.Decimal(5, 2) @map("gst_rate")
  gstAmount     Decimal  @default(0) @db.Decimal(10, 2) @map("gst_amount")
  discount      Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal  @db.Decimal(10, 2) @map("total_amount")
  
  // HSN/SAC Code for GST
  hsnCode       String?  @map("hsn_code")
  sacCode       String?  @map("sac_code")
  
  createdAt     DateTime @default(now()) @map("created_at")
  
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item          Item?    @relation(fields: [itemId], references: [id])
  batches       InvoiceItemBatch[]
  
  @@index([invoiceId])
  @@map("invoice_items")
}

model InvoiceItemBatch {
  id            String   @id @default(uuid())
  invoiceItemId String   @map("invoice_item_id")
  batchId       String   @map("batch_id")
  quantity      Decimal  @db.Decimal(10, 3)
  createdAt     DateTime @default(now()) @map("created_at")
  
  invoiceItem   InvoiceItem @relation(fields: [invoiceItemId], references: [id], onDelete: Cascade)
  batch         InventoryBatch @relation(fields: [batchId], references: [id])
  
  @@index([invoiceItemId])
  @@index([batchId])
  @@map("invoice_item_batches")
}

model InvoicePayment {
  id            String   @id @default(uuid())
  invoiceId     String   @map("invoice_id")
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String   @map("payment_method")
  paymentDate   DateTime @default(now()) @map("payment_date")
  reference     String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  
  @@index([invoiceId])
  @@map("invoice_payments")
}

// ============================================
// Bank Accounts - Multiple per Location
// ============================================
model BankAccount {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  locationId        String    @map("location_id")
  
  accountName       String    @map("account_name") // "ICICI Primary"
  bankName          String    @map("bank_name")
  accountNumber     String    @map("account_number")
  accountHolderName String    @map("account_holder_name")
  ifscCode          String    @map("ifsc_code")
  branchName        String?   @map("branch_name")
  accountType       String    @default("CURRENT") @map("account_type") // SAVINGS, CURRENT
  upiId             String?   @map("upi_id")
  qrCodeUrl         String?   @map("qr_code_url") // Supabase Storage URL
  
  isDefault         Boolean   @default(false) @map("is_default")
  isActive          Boolean   @default(true) @map("is_active")
  
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  location          Location  @relation(fields: [locationId], references: [id])
  invoices          Invoice[]
  
  @@unique([locationId, accountName])
  @@index([tenantId, locationId])
  @@index([locationId, isDefault])
  @@map("bank_accounts")
}

// ============================================
// Transport Agents - Reusable per Location
// ============================================
model TransportAgent {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  locationId      String   @map("location_id")
  
  agentName       String   @map("agent_name") // "Silver Roadlines"
  transporterId   String?  @map("transporter_id") // GST No or Transport ID
  contactPerson   String?  @map("contact_person")
  phone           String?
  email           String?
  address         String?  @db.Text
  defaultMode     String?  @map("default_mode") // Road, Rail, Air, Ship
  
  isActive        Boolean  @default(true) @map("is_active")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  location        Location @relation(fields: [locationId], references: [id])
  invoices        Invoice[]
  
  @@unique([locationId, agentName])
  @@index([tenantId, locationId])
  @@map("transport_agents")
}

// ============================================
// BRANDING - Company/Brand Profiles
// ============================================
model Branding {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  locationId      String   @map("location_id")
  
  // Brand identification
  name            String   // "Summer Collection", "Corporate Brand", "Main Brand"
  isDefault       Boolean  @default(false) @map("is_default")
  
  // Company Information
  businessName    String?  @map("business_name")
  companyTagline  String?  @db.Text @map("company_tagline")
  address         String?  @db.Text
  city            String?
  state           String?
  pincode         String?
  phone           String?
  email           String?
  website         String?
  
  // Registration Numbers
  gstNumber       String?  @map("gst_number")
  panNumber       String?  @map("pan_number")
  cinNumber       String?  @map("cin_number")
  
  // Visual Branding
  logoUrl         String?  @map("logo_url")
  logoPosition    String?  @default("left") @map("logo_position") // left, center, right
  logoWidth       Int?     @default(150) @map("logo_width")
  primaryColor    String?  @default("#1e40af") @map("primary_color")
  accentColor     String?  @default("#3b82f6") @map("accent_color")
  
  // Signature & Stamp
  signatureUrl    String?  @map("signature_url")
  signatureText   String?  @default("Authorized Signatory") @map("signature_text")
  stampUrl        String?  @map("stamp_url")
  
  // Status
  isActive        Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  
  // Relations
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  location        Location @relation(fields: [locationId], references: [id])
  
  @@unique([locationId, name])
  @@index([tenantId, locationId])
  @@index([locationId, isDefault])
  @@map("brandings")
}

// ============================================
// HSN Codes - Master Data for Products
// ============================================
model HSNCode {
  id          String   @id @default(uuid())
  code        String   @unique // "8471" (4-8 digits)
  description String   @db.Text
  chapter     String?  // "84" (first 2 digits)
  heading     String?  // "8471"
  gstRate     Decimal? @db.Decimal(5, 2) @map("gst_rate")
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([code])
  @@index([chapter])
  @@map("hsn_codes")
}

// ============================================
// SAC Codes - Master Data for Services
// ============================================
model SACCode {
  id          String   @id @default(uuid())
  code        String   @unique // "998314" (6 digits)
  description String   @db.Text
  category    String?  // "Technical testing"
  gstRate     Decimal? @db.Decimal(5, 2) @map("gst_rate")
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@index([code])
  @@index([category])
  @@map("sac_codes")
}
